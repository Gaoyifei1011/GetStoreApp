<Page
    x:Class="GetStoreApp.Views.Pages.SearchStorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:GetStoreApp.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:GetStoreApp.Models"
    xmlns:rootservice="using:GetStoreApp.Services.Root"
    x:Name="SearchStoreRoot"
    Padding="0,0,0,30"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ExpanderChevronPointerOverBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ExpanderChevronPressedBackground" Color="Transparent" />
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPressed" Color="Transparent" />

        <XamlUICommand x:Name="DeleteCommand" ExecuteRequested="{x:Bind OnDeleteExecuteRequested}" />
        <XamlUICommand x:Name="CopyLinkCommand" ExecuteRequested="{x:Bind OnCopyLinkExecuteRequested}" />
        <XamlUICommand x:Name="OpenLinkCommand" ExecuteRequested="{x:Bind OnOpenLinkExecuteRequested}" />
        <XamlUICommand x:Name="QueryLinksCommand" ExecuteRequested="{x:Bind OnQueryLinksExecuteRequested}" />
    </Page.Resources>

    <ScrollViewer
        Padding="30,0,30,0"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">

        <Grid Margin="0,0,0,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,1,3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    Grid.Column="0"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    DisplayMemberPath="DisplayMember"
                    IsEnabled="{x:Bind IsSearchingStore.Equals(x:False), Mode=OneWay}"
                    ItemsSource="{x:Bind SearchTypeList}"
                    SelectedItem="{x:Bind SelectedSearchType, Mode=OneWay}"
                    SelectionChanged="{x:Bind OnSearchTypeSelectionChanged}"
                    Style="{StaticResource ComboBoxStyle}" />

                <AutoSuggestBox
                    x:Name="SearchStoreHistoryAutoSuggestBox"
                    Grid.Column="1"
                    Margin="0,0,6,0"
                    GotFocus="{x:Bind OnAutoSuggestBoxGotFocus}"
                    IsEnabled="{x:Bind IsSearchingStore.Equals(x:False), Mode=OneWay}"
                    ItemContainerStyle="{StaticResource AutoSuggestBoxListViewItemStyle}"
                    ItemsSource="{x:Bind HistoryCollection}"
                    LosingFocus="{x:Bind OnLosingFocus}"
                    LostFocus="{x:Bind OnAutoSuggestBoxLostFocus}"
                    PlaceholderText="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/SearchPlaceHolderText')}"
                    QuerySubmitted="{x:Bind OnQuerySubmitted}"
                    Style="{StaticResource AutoSuggestBoxStyle}"
                    SuggestionChosen="{x:Bind OnSuggestionChosen}"
                    Text="{x:Bind SearchText, Mode=OneWay}"
                    TextChanged="{x:Bind OnTextChanged}"
                    UpdateTextOnSelect="False">

                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="model:HistoryModel">
                            <Grid Height="60" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Grid.Column="0"
                                    Width="30"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ControlCornerRadius}">

                                    <FontIcon FontSize="16" Glyph="&#xE81C;" />
                                </Grid>

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind HistoryContent}" />

                                <Button
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    Margin="3,0,3,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource DeleteCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    IsEnabled="{x:Bind IsQuerying.Equals(x:False), Mode=OneWay}"
                                    Style="{StaticResource AlternateCloseButtonStyle}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/Delete')}">

                                    <FontIcon
                                        Margin="4"
                                        FontSize="16"
                                        Glyph="&#xE711;" />
                                </Button>

                                <ToolTipService.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/HistoryContent')}" />
                                                <Run Text="{x:Bind HistoryContent}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>

                <Button
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Click="{x:Bind OnSearchStoreClicked}"
                    Content="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/SearchStore')}"
                    IsEnabled="{x:Bind CheckSearchStoreState(IsSearchingStore, IsSelectMode), Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>

            <InfoBar
                Grid.Row="1"
                Height="50"
                Margin="0,0,0,3"
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind StateInfoText, Mode=OneWay}"
                Severity="{x:Bind ResultSeverity, Mode=OneWay}">

                <InfoBar.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Default">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="CardBackgroundFillColorDefaultBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="HighConstract">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="CardBackgroundFillColorDefaultBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </InfoBar.Resources>

                <InfoBar.ActionButton>
                    <Button
                        Margin="0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind IsRingActive, Mode=OneWay}">

                        <ProgressRing IsActive="{x:Bind IsRingActive, Mode=OneWay}" IsIndeterminate="True" />
                    </Button>
                </InfoBar.ActionButton>
            </InfoBar>

            <Grid
                Grid.Row="2"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Visibility="{x:Bind ResultControlVisible, Mode=OneWay}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    Grid.Row="0"
                    Height="60"
                    Padding="16,8,2,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4,4,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        FontSize="16"
                        Glyph="&#xE71E;" />

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/SearchResult')}" />

                    <AppBarSeparator Grid.Column="2" Margin="10,0,10,0" />

                    <TextBlock
                        Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{x:Bind x:String.Format(SearchStoreCountInfo, SearchStoreCollection.Count), Mode=OneWay}"
                        Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(SearchStoreCollection.Count), Mode=OneWay}" />

                    <TextBlock
                        Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/SearchStoreEmpty')}"
                        Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityReverseConvert(SearchStoreCollection.Count), Mode=OneWay}" />
                </Grid>

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind SearchStoreCollection}"
                    SelectionMode="None"
                    Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(SearchStoreCollection.Count), Mode=OneWay}">

                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ItemsControl.ItemContainerTransitions>
                        <TransitionCollection />
                    </ItemsControl.ItemContainerTransitions>

                    <ListView.Header>
                        <Grid
                            Height="35"
                            Padding="6,0,0,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,0,1,1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="95" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="StoreAppNameHeaderText"
                                Grid.Column="0"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppName')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppName')}" Visibility="{x:Bind StoreAppNameHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>

                            <TextBlock
                                x:Name="StoreAppPublisherHeaderText"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppPublisher')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppPublisher')}" Visibility="{x:Bind StoreAppPublisherHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>

                            <TextBlock
                                x:Name="StoreAppLinkHeaderText"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppLink')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/StoreAppLink')}" Visibility="{x:Bind StoreAppLinkHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>

                            <TextBlock
                                Grid.Column="3"
                                Grid.ColumnSpan="3"
                                Margin="0,0,10,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/Options')}"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/OptionsToolTip')}" />
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:SearchStoreModel">
                            <Grid
                                Height="35"
                                Padding="6,0,0,0"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1,0,1,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="95" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Name="StoreAppNameText"
                                    Grid.Column="0"
                                    MinWidth="50"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind StoreAppName}"
                                    TextAlignment="Left"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind StoreAppName}" Visibility="{Binding ElementName=StoreAppNameText, Path=IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <TextBlock
                                    x:Name="StoreAppPublisherText"
                                    Grid.Column="1"
                                    MinWidth="50"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind StoreAppPublisher}"
                                    TextAlignment="Left"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind StoreAppPublisher}" Visibility="{Binding ElementName=StoreAppPublisherText, Path=IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <HyperlinkButton
                                    Grid.Column="2"
                                    Margin="10,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource OpenLinkCommand}"
                                    CommandParameter="{x:Bind StoreAppLink}">

                                    <TextBlock
                                        Text="{x:Bind StoreAppLink}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        ToolTipService.ToolTip="{x:Bind StoreAppLink}" />

                                    <HyperlinkButton.ContextFlyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem
                                                Command="{StaticResource CopyLinkCommand}"
                                                CommandParameter="{x:Bind StoreAppLink}"
                                                Text="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/CopyLink')}"
                                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/CopyLinkToolTip')}">

                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8C8;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </HyperlinkButton.ContextFlyout>
                                </HyperlinkButton>

                                <HyperlinkButton
                                    Grid.Column="3"
                                    Margin="0,0,5,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource QueryLinksCommand}"
                                    CommandParameter="{x:Bind StoreAppLink}"
                                    Content="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/QueryLinks')}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('SearchStore/QueryLinksToolTip')}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
