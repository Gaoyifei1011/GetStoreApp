<Page
    x:Class="GetStoreApp.Views.Pages.QueryLinksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:GetStoreApp.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:GetStoreApp.Models"
    xmlns:rootservice="using:GetStoreApp.Services.Root"
    x:Name="QueryLinksRoot"
    Padding="0,0,0,30"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ExpanderChevronPointerOverBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ExpanderChevronPressedBackground" Color="Transparent" />
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPressed" Color="Transparent" />

        <XamlUICommand x:Name="CopyHistoryCommand" ExecuteRequested="{x:Bind OnCopyHistoryExecuteRequested}" />
        <XamlUICommand x:Name="DeleteCommand" ExecuteRequested="{x:Bind OnDeleteExecuteRequested}" />
        <XamlUICommand x:Name="DownloadCommand" ExecuteRequested="{x:Bind OnDownloadExecuteRequested}" />
        <XamlUICommand x:Name="OpenLinkCommand" ExecuteRequested="{x:Bind OnOpenLinkExecuteRequested}" />
        <XamlUICommand x:Name="CopyLinkCommand" ExecuteRequested="{x:Bind OnCopyLinkExecuteRequested}" />
        <XamlUICommand x:Name="CopyInformationCommand" ExecuteRequested="{x:Bind OnCopyInformationExecuteRequested}" />
    </Page.Resources>

    <ScrollViewer
        Padding="30,0,30,0"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">

        <Grid Margin="0,0,0,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  查询链接控制栏  -->
            <Grid
                Grid.Row="0"
                Margin="0,0,1,3"
                ColumnSpacing="6">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    DisplayMemberPath="DisplayName"
                    IsEnabled="{x:Bind IsQueryingLinks.Equals(x:False), Mode=OneWay}"
                    ItemsSource="{x:Bind TypeList}"
                    SelectedItem="{x:Bind SelectedType, Mode=OneWay}"
                    SelectionChanged="{x:Bind OnTypeSelectionChanged}"
                    Style="{StaticResource ComboBoxStyle}" />

                <ComboBox
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    DisplayMemberPath="DisplayName"
                    IsEnabled="{x:Bind IsQueryingLinks.Equals(x:False), Mode=OneWay}"
                    ItemsSource="{x:Bind ChannelList}"
                    SelectedItem="{x:Bind SelectedChannel, Mode=OneWay}"
                    SelectionChanged="{x:Bind OnChannelSelectionChanged}"
                    Style="{StaticResource ComboBoxStyle}" />

                <AutoSuggestBox
                    x:Name="QueryLinksHistoryAutoSuggestBox"
                    Grid.Column="2"
                    GotFocus="{x:Bind OnAutoSuggestBoxGotFocus}"
                    IsEnabled="{x:Bind IsQueryingLinks.Equals(x:False), Mode=OneWay}"
                    ItemContainerStyle="{StaticResource AutoSuggestBoxListViewItemStyle}"
                    ItemsSource="{x:Bind HistoryCollection}"
                    LosingFocus="{x:Bind OnLosingFocus}"
                    LostFocus="{x:Bind OnAutoSuggestBoxLostFocus}"
                    PlaceholderText="{x:Bind LinkPlaceHolderText, Mode=OneWay}"
                    QuerySubmitted="{x:Bind OnQuerySubmitted}"
                    Style="{StaticResource AutoSuggestBoxStyle}"
                    SuggestionChosen="{x:Bind OnSuggestionChosen}"
                    Text="{x:Bind LinkText, Mode=OneWay}"
                    TextChanged="{x:Bind OnTextChanged}"
                    UpdateTextOnSelect="False">

                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="model:HistoryModel">
                            <Grid Height="60" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Grid.Column="0"
                                    Width="30"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ControlCornerRadius}">

                                    <FontIcon FontSize="16" Glyph="&#xE81C;" />
                                </Grid>

                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical">

                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{x:Bind HistoryAppName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />

                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">

                                        <Run Text="{x:Bind HistoryTypeName}" />
                                        <Run Text=" | " />
                                        <Run Text="{x:Bind HistoryChannelName}" />
                                        <Run Text=" | " />
                                        <Run Text="{x:Bind HistoryLink}" />
                                    </TextBlock>
                                </StackPanel>

                                <Button
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    Margin="3,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource CopyHistoryCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    IsEnabled="{x:Bind IsQuerying.Equals(x:False), Mode=OneWay}"
                                    Style="{StaticResource AlternateCloseButtonStyle}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyInformation')}">

                                    <FontIcon
                                        Margin="4"
                                        FontSize="16"
                                        Glyph="&#xE8C8;" />
                                </Button>

                                <Button
                                    Grid.Column="3"
                                    Width="32"
                                    Height="32"
                                    Margin="3,0,3,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource DeleteCommand}"
                                    CommandParameter="{x:Bind}"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    IsEnabled="{x:Bind IsQuerying.Equals(x:False), Mode=OneWay}"
                                    Style="{StaticResource AlternateCloseButtonStyle}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Delete')}">

                                    <FontIcon
                                        Margin="4"
                                        FontSize="16"
                                        Glyph="&#xE711;" />
                                </Button>

                                <ToolTipService.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/HistoryAppName')}" />
                                                <Run Text="{x:Bind HistoryAppName}" />
                                            </TextBlock>

                                            <TextBlock>
                                                <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/HistoryType')}" />
                                                <Run Text="{x:Bind HistoryTypeName}" />
                                            </TextBlock>

                                            <TextBlock>
                                                <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/HistoryChannel')}" />
                                                <Run Text="{x:Bind HistoryChannelName}" />
                                            </TextBlock>

                                            <TextBlock>
                                                <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/HistoryLink')}" />
                                                <Run Text="{x:Bind HistoryLink}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>

                <Button
                    Grid.Column="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Click="{x:Bind OnQueryLinksClicked}"
                    Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueryLinks')}"
                    IsEnabled="{x:Bind CheckQueryLinksState(IsQueryingLinks, IsSelectMode), Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>

            <!--  查询链接信息栏  -->
            <InfoBar
                Grid.Row="1"
                Height="50"
                Margin="0,0,0,3"
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind StateInfoText, Mode=OneWay}"
                Severity="{x:Bind ResultSeverity, Mode=OneWay}">

                <InfoBar.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Default">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="CardBackgroundFillColorDefaultBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="HighConstract">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="InfoBarInformationalSeverityBackgroundBrush" ResourceKey="CardBackgroundFillColorDefaultBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </InfoBar.Resources>

                <InfoBar.ActionButton>
                    <Button
                        Margin="0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind IsRingActive, Mode=OneWay}">

                        <ProgressRing IsActive="{x:Bind IsRingActive, Mode=OneWay}" IsIndeterminate="True" />
                    </Button>
                </InfoBar.ActionButton>
            </InfoBar>

            <!--  查询链接结果  -->
            <Grid
                Grid.Row="2"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Visibility="{x:Bind ResultControlVisible, Mode=OneWay}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  查询链接结果信息栏  -->
                <Expander
                    Grid.Row="0"
                    Margin="0,0,0,3"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    IsExpanded="True"
                    Visibility="{x:Bind IsAppInfoVisible, Mode=OneWay}">

                    <Expander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                Grid.Column="0"
                                Margin="0,0,12,0"
                                FontSize="16"
                                Glyph="&#xE946;" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,0,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueriedAppInfo')}" />

                            <CommandBar
                                Grid.Column="2"
                                Margin="0,0,-15,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                DefaultLabelPosition="Right"
                                Style="{StaticResource CommandBarStyle}">

                                <CommandBar.PrimaryCommands>
                                    <AppBarButton Click="{x:Bind OnCopyQueriedAppInfoClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyQueriedAppInfo')}">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE8C8;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>

                                    <AppBarButton Click="{x:Bind OnLearnMoreClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/LearnMore')}">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE890;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                </CommandBar.PrimaryCommands>
                            </CommandBar>
                        </Grid>
                    </Expander.Header>

                    <Grid Margin="0,0,10,0" RowSpacing="6">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueriedAppName')}" />

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Name, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueriedAppPublisher')}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Publisher, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueriedAppDescription')}" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Description, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />
                    </Grid>
                </Expander>

                <!--  查询链接结果控制栏  -->
                <Grid
                    Grid.Row="1"
                    Height="60"
                    Padding="16,8,2,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        FontSize="16"
                        Glyph="&#xE71E;" />

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueryResult')}" />

                    <AppBarSeparator Grid.Column="2" Margin="10,0,10,0" />

                    <StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(QueryLinksCollection.Count), Mode=OneWay}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueriedAppType')}" />

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/NonPackagedApp')}"
                                Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsPackagedApp), Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/PackagedApp')}"
                                Visibility="{x:Bind IsPackagedApp, Mode=OneWay}" />
                        </Grid>

                        <TextBlock Text="{x:Bind x:String.Format(QueryLinksCountInfoString, QueryLinksCollection.Count), Mode=OneWay}" />
                    </StackPanel>

                    <TextBlock
                        Grid.Column="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/QueryLinksEmpty')}"
                        Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityReverseConvert(QueryLinksCollection.Count), Mode=OneWay}" />

                    <CommandBar
                        x:Name="NormalMode"
                        Grid.Column="5"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        DefaultLabelPosition="Right"
                        Style="{StaticResource CommandBarStyle}"
                        Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsSelectMode), Mode=OneWay}">

                        <CommandBar.PrimaryCommands>
                            <AppBarButton
                                Click="{x:Bind OnSelectClicked}"
                                Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Select')}"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/SelectToolTip')}">

                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE762;" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                        </CommandBar.PrimaryCommands>
                    </CommandBar>

                    <CommandBar
                        x:Name="SelectMode"
                        Grid.Column="5"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        DefaultLabelPosition="Right"
                        Style="{StaticResource CommandBarStyle}"
                        Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                        <CommandBar.PrimaryCommands>
                            <AppBarButton Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyOptions')}" ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyOptionsToolTip')}">

                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </AppBarButton.Icon>

                                <AppBarButton.Flyout>
                                    <MenuFlyout Placement="Bottom">
                                        <MenuFlyoutItem
                                            Click="{x:Bind OnCopySelectedLinkClicked}"
                                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopySelectedLink')}"
                                            ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopySelectedLinkToolTip')}" />

                                        <MenuFlyoutItem
                                            Click="{x:Bind OnCopySelectedClicked}"
                                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopySelectedContent')}"
                                            ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopySelectedContentToolTip')}" />
                                    </MenuFlyout>
                                </AppBarButton.Flyout>
                            </AppBarButton>

                            <AppBarButton Click="{x:Bind OnDownloadSelectedClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/DownloadSelected')}">

                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE74B;" />
                                </AppBarButton.Icon>
                            </AppBarButton>

                            <AppBarButton
                                Click="{x:Bind OnCancelClicked}"
                                Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Cancel')}"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CancelToolTip')}">

                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE711;" />
                                </AppBarButton.Icon>
                            </AppBarButton>
                        </CommandBar.PrimaryCommands>
                    </CommandBar>
                </Grid>

                <!--  查询链接结果列表  -->
                <ListView
                    Grid.Row="2"
                    CornerRadius="0"
                    IsItemClickEnabled="{x:Bind IsSelectMode, Mode=OneWay}"
                    ItemClick="{x:Bind OnItemClick}"
                    ItemsSource="{x:Bind QueryLinksCollection}"
                    SelectionMode="None"
                    Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(QueryLinksCollection.Count), Mode=OneWay}">

                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ItemsControl.ItemContainerTransitions>
                        <TransitionCollection />
                    </ItemsControl.ItemContainerTransitions>

                    <ListView.Header>
                        <Grid
                            Height="35"
                            Padding="6,0,0,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,0,1,1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="SelectHeaderText"
                                Grid.Column="0"
                                Width="50"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/SelectHeader')}"
                                Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                                <Hyperlink Click="{x:Bind OnSelectHeaderClicked}" UnderlineStyle="None">
                                    <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Select')}" />
                                </Hyperlink>
                            </TextBlock>

                            <TextBlock
                                x:Name="FileNameHeaderText"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/FileName')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/FileName')}" Visibility="{x:Bind FileNameHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>

                            <TextBlock
                                x:Name="FileSizeHeaderText"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/FileSize')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/FileSize')}" Visibility="{x:Bind FileSizeHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>

                            <TextBlock
                                Grid.Column="3"
                                Margin="0,0,10,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Options')}"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/OptionsToolTip')}" />
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:QueryLinksModel">
                            <Grid
                                Height="35"
                                Padding="6,0,0,0"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1,0,1,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Grid.Column="0"
                                    Width="50"
                                    MinWidth="0"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                    IsThreeState="False"
                                    Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                                    <ToolTipService.ToolTip>
                                        <ToolTip>
                                            <Grid>
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/Selected')}" Visibility="{x:Bind IsSelected, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/UnSelected')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsSelected), Mode=OneWay}" />
                                            </Grid>
                                        </ToolTip>
                                    </ToolTipService.ToolTip>
                                </CheckBox>

                                <HyperlinkButton
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource DownloadCommand}"
                                    CommandParameter="{x:Bind}"
                                    IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}">

                                    <TextBlock
                                        x:Name="FileNameText"
                                        HorizontalAlignment="Left"
                                        Text="{x:Bind FileName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">

                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="{x:Bind FileName}" Visibility="{Binding ElementName=FileNameText, Path=IsTextTrimmed, Mode=OneWay}" />
                                        </ToolTipService.ToolTip>
                                    </TextBlock>

                                    <HyperlinkButton.ContextFlyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem
                                                Command="{StaticResource CopyLinkCommand}"
                                                CommandParameter="{x:Bind FileLink}"
                                                IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyLink')}"
                                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyLinkToolTip')}">

                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8C8;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </HyperlinkButton.ContextFlyout>
                                </HyperlinkButton>

                                <TextBlock
                                    x:Name="FileSizeText"
                                    Grid.Column="2"
                                    MinWidth="50"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind FileSize}"
                                    TextAlignment="Left"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind FileSize}" Visibility="{Binding ElementName=FileSizeText, Path=IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <HyperlinkButton
                                    Grid.Column="3"
                                    Margin="0,0,5,0"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource OpenLinkCommand}"
                                    CommandParameter="{x:Bind FileLink}"
                                    Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/OpenLink')}"
                                    IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/OpenLinkToolTip')}" />

                                <Grid.ContextFlyout>
                                    <MenuFlyout Placement="Bottom">
                                        <MenuFlyoutItem
                                            Command="{StaticResource CopyInformationCommand}"
                                            CommandParameter="{x:Bind}"
                                            IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyInformation')}"
                                            ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinks/CopyInformationToolTip')}">

                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
