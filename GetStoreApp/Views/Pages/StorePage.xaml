<Page
    x:Class="GetStoreApp.Views.Pages.StorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:GetStoreApp.Extensions.DataType.Enums"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rootservice="using:GetStoreApp.Services.Root"
    xmlns:usercontrol="using:GetStoreApp.Views.UserControls"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <SplitView
        x:Name="StoreSplitView"
        DisplayMode="Overlay"
        OpenPaneLength="320"
        PaneBackground="Transparent"
        PanePlacement="Right">

        <Grid>
            <!--  商店选择器用户控件  -->
            <usercontrol:StoreSelectorUserControl
                x:Name="StoreSelector"
                x:FieldModifier="public"
                Visibility="{x:Bind GetSelectedStoreControl(StoreControl, enum:StoreControl.StoreSelector), Mode=OneWay}" />
        </Grid>

        <SplitView.Pane>
            <!--  使用说明  -->
            <Grid Margin="0,10,0,0" CornerRadius="4,0,0,0">
                <SystemBackdropElement CornerRadius="4,0,0,0" SystemBackdrop="{StaticResource AcrylicBackgroundFillColorDefaultBackdrop}" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="16,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Glyph="&#xE946;" />

                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,0,2"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/UseInstruction')}" />

                        <Button
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="{x:Bind OnCloseClicked}"
                            Style="{StaticResource AlternateCloseButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('Store/Close')}">

                            <FontIcon
                                Margin="4"
                                FontSize="16"
                                Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Visible"
                        VerticalScrollMode="Enabled">

                        <Grid Margin="0,0,0,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Margin="16,10,16,10"
                                FontSize="15"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/BeginnerGuide')}"
                                TextAlignment="Left" />

                            <TextBlock
                                Grid.Row="1"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/QueryLinksHelp1')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="2"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/QueryLinksHelp2')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/SearchAppsHelp1')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="4"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/SearchAppsHelp2')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="5"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/SearchAppsHelp3')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <MenuFlyoutSeparator Grid.Row="6" />

                            <TextBlock
                                Grid.Row="7"
                                Margin="16,10,16,10"
                                FontSize="15"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/LaunchParameters')}"
                                TextAlignment="Left" />

                            <TextBlock
                                Grid.Row="8"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/LaunchParametersDescription')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <StackPanel
                                Grid.Row="9"
                                Margin="16,0,16,5"
                                Spacing="5">

                                <TextBlock HorizontalAlignment="Left">
                                    <Hyperlink Click="{x:Bind OnDesktopLaunchClicked}" UnderlineStyle="None">
                                        <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DesktopLaunch')}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <MenuFlyoutSeparator Grid.Row="10" />

                            <TextBlock
                                Grid.Row="11"
                                Margin="16,10,16,10"
                                FontSize="15"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailed')}"
                                TextAlignment="Left" />

                            <TextBlock
                                Grid.Row="12"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailedDescription')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="13"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailedStep1')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="14"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailedStep2')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="15"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailedStep3')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="16"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/RequestFailedStep4')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <StackPanel
                                Grid.Row="17"
                                Margin="16,0,16,5"
                                Spacing="5">

                                <TextBlock HorizontalAlignment="Left">
                                    <Hyperlink Click="{x:Bind OnCheckNetWorkClicked}" UnderlineStyle="None">
                                        <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/CheckNetwork')}" />
                                    </Hyperlink>
                                </TextBlock>

                                <TextBlock HorizontalAlignment="Left">
                                    <Hyperlink Click="{x:Bind OnTroubleShootClicked}" UnderlineStyle="None">
                                        <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/TroubleShoot')}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <MenuFlyoutSeparator Grid.Row="18" />

                            <TextBlock
                                Grid.Row="19"
                                Margin="16,10,16,10"
                                FontSize="15"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/PaidApps')}"
                                TextAlignment="Left" />

                            <TextBlock
                                Grid.Row="20"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/PaidAppsDescription')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <MenuFlyoutSeparator Grid.Row="21" />

                            <TextBlock
                                Grid.Row="22"
                                Margin="16,10,16,10"
                                FontSize="15"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DownloadFailed')}"
                                TextAlignment="Left" />

                            <TextBlock
                                Grid.Row="23"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DownloadFailedDescription')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="24"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DownloadFailedStep1')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="25"
                                Margin="16,0,16,5"
                                FontSize="14"
                                FontWeight="Normal"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DownloadFailedStep2')}"
                                TextAlignment="Justify"
                                TextWrapping="Wrap" />

                            <StackPanel
                                Grid.Row="26"
                                Margin="16,0,16,5"
                                Spacing="5">

                                <TextBlock HorizontalAlignment="Left">
                                    <Hyperlink Click="{x:Bind OnDownloadSettingsClicked}" UnderlineStyle="None">
                                        <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('Store/DownloadSettings')}" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </SplitView.Pane>
    </SplitView>
</Page>
