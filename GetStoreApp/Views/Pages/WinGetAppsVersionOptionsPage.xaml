                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowedArchitectures')}" />

                        <ToggleButton
                            Grid.Column="1"
                            Margin="6,0,4,0"
                            Click="{x:Bind OnProcessorArchitectureClicked}"
                            Content="{x:Bind system:Convert.ToString(winrtsystem:ProcessorArchitecture.X86)}"
                            IsChecked="{x:Bind IsX86ProcessorArchitecture, Mode=OneWay}"
                            Tag="{x:Bind winrtsystem:ProcessorArchitecture.X86}" />

                        <ToggleButton
                            Grid.Column="2"
                            Margin="0,0,4,0"
                            Click="{x:Bind OnProcessorArchitectureClicked}"
                            Content="{x:Bind system:Convert.ToString(winrtsystem:ProcessorArchitecture.X64)}"
                            IsChecked="{x:Bind IsX64ProcessorArchitecture, Mode=OneWay}"
                            Tag="{x:Bind winrtsystem:ProcessorArchitecture.X64}" />

                        <ToggleButton
                            Grid.Column="3"
                            Click="{x:Bind OnProcessorArchitectureClicked}"
                            Content="{x:Bind system:Convert.ToString(winrtsystem:ProcessorArchitecture.Arm64)}"
                            IsChecked="{x:Bind IsArm64ProcessorArchitecture, Mode=OneWay}"
                            Tag="{x:Bind winrtsystem:ProcessorArchitecture.Arm64}" />
                    </Grid>

                    <!--  额外安装参数  -->
                    <Grid
                        Grid.Row="8"
                        Height="60"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AdditionalInstallerArguments')}" />

                        <TextBox
                            Grid.Column="1"
                            MinWidth="240"
                            VerticalAlignment="Center"
                            Text="{x:Bind AdditionalInstallerArguments, Mode=OneWay}"
                            TextChanged="{x:Bind OnAdditionalInstallerArgumentsTextChanged}" />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
