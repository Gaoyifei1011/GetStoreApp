<Page
    x:Class="GetStoreApp.Views.Pages.WinGetAppsVersionOptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:GetStoreApp.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:GetStoreApp.Extensions.DataType.Enums"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rootservice="using:GetStoreApp.Services.Root"
    xmlns:system="using:System"
    xmlns:winrtsystem="using:Windows.System"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid>
        <!--  下载应用控件  -->
        <Grid x:Name="DownloadGrid" x:Load="{x:Bind x:Object.Equals(PackageOperationKind, enum:PackageOperationKind.Download), Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="10,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Text="{x:Bind WinGetAppsOptionsTitle, Mode=OneWay}" />

                <CommandBar
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    DefaultLabelPosition="Right">

                    <CommandBar.PrimaryCommands>
                        <AppBarButton Click="{x:Bind OnDownloadClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/Download')}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE896;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.PrimaryCommands>
                </CommandBar>

                <Button
                    Grid.Column="2"
                    MinHeight="{ThemeResource AppBarThemeCompactHeight}"
                    Margin="-6,0,0,0"
                    Padding="{ThemeResource CommandBarMoreButtonMargin}"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource CommandBarForeground}"
                    IsAccessKeyScope="True"
                    Style="{ThemeResource EllipsisButton}">

                    <FontIcon
                        Height="{ThemeResource AppBarExpandButtonCircleDiameter}"
                        VerticalAlignment="Center"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="20"
                        Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnCopyDownloadTextClicked}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/CopyDownloadText')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Click="{x:Bind OnDownloadWithCmdClicked}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/DownloadWithCmd')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE756;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>

                    <ToolTipService.ToolTip>
                        <ToolTip
                            MaxWidth="9999"
                            Padding="0"
                            Background="Transparent">

                            <Grid>
                                <SystemBackdropElement CornerRadius="{StaticResource ControlCornerRadius}" SystemBackdrop="{StaticResource AcrylicBackgroundFillColorDefaultBackdrop}" />
                                <TextBlock Padding="{StaticResource ToolTipBorderPadding}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ViewMore')}" />
                            </Grid>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                </Button>
            </Grid>

            <MenuFlyoutSeparator Grid.Row="1" />

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Visible"
                VerticalScrollMode="Enabled">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  忽略安装程序哈希检查失败  -->
                    <Grid
                        Grid.Row="0"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatch')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind AllowHashMismatch, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatchOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatchOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnAllowHashMismatchToggled}" />
                    </Grid>

                    <!--  安装包架构  -->
                    <Grid
                        Grid.Row="1"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageArchitecture')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind PackageArchitectureList}"
                            SelectedItem="{x:Bind PackageArchitecture, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnPackageArchitectureSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <!--  安装包安装范围  -->
                    <Grid
                        Grid.Row="2"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageInstallScope')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind PackageInstallScopeList}"
                            SelectedItem="{x:Bind PackageInstallScope, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnPackageInstallScopeSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <!--  安装程序下载到的目录  -->
                    <Grid
                        Grid.Row="3"
                        Height="60"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageDownloadPath')}" />

                            <TextBlock
                                Margin="0,0,5,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"
                                Visibility="{x:Bind CheckPackagePath(PackageDownloadPath), Mode=OneWay}">

                                <Hyperlink Click="{x:Bind OnPackageDownloadPathClicked}" UnderlineStyle="None">
                                    <Run Text="{x:Bind PackageDownloadPath, Mode=OneWay}" />
                                </Hyperlink>

                                <ToolTipService.ToolTip>
                                    <ToolTip
                                        MaxWidth="9999"
                                        Padding="0"
                                        Background="Transparent">

                                        <Grid>
                                            <SystemBackdropElement CornerRadius="{StaticResource ControlCornerRadius}" SystemBackdrop="{StaticResource AcrylicBackgroundFillColorDefaultBackdrop}" />

                                            <StackPanel Padding="{StaticResource ToolTipBorderPadding}" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageDownloadPath')}" />
                                                <TextBlock Text="{x:Bind PackageDownloadPath, Mode=OneWay}" />
                                                <MenuFlyoutSeparator Margin="4,3" />
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/OpenFolder')}" />
                                            </StackPanel>
                                        </Grid>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <DropDownButton
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Content="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ChangeFolder')}">

                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem
                                        Click="{x:Bind OnChangePackageDownloadPathClicked}"
                                        Tag="AppCache"
                                        Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AppCacheFolder')}">

                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xECAA;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutItem
                                        Click="{x:Bind OnChangePackageDownloadPathClicked}"
                                        Tag="Download"
                                        Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/DownloadFolder')}">

                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE896;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutItem
                                        Click="{x:Bind OnChangePackageDownloadPathClicked}"
                                        Tag="Desktop"
                                        Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/DesktopFolder')}">

                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE7F4;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>

                                    <MenuFlyoutSeparator />

                                    <MenuFlyoutItem
                                        Click="{x:Bind OnChangePackageDownloadPathClicked}"
                                        Tag="Custom"
                                        Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/Custom')}" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!--  安装应用控件  -->
        <Grid x:Name="InstallGrid" x:Load="{x:Bind x:Object.Equals(PackageOperationKind, enum:PackageOperationKind.Install), Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="10,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Text="{x:Bind WinGetAppsOptionsTitle, Mode=OneWay}" />

                <CommandBar
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    DefaultLabelPosition="Right">

                    <CommandBar.PrimaryCommands>
                        <AppBarButton Click="{x:Bind OnInstallClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/Install')}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE710;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.PrimaryCommands>
                </CommandBar>

                <Button
                    Grid.Column="2"
                    MinHeight="{ThemeResource AppBarThemeCompactHeight}"
                    Margin="-6,0,0,0"
                    Padding="{ThemeResource CommandBarMoreButtonMargin}"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource CommandBarForeground}"
                    IsAccessKeyScope="True"
                    Style="{ThemeResource EllipsisButton}">

                    <FontIcon
                        Height="{ThemeResource AppBarExpandButtonCircleDiameter}"
                        VerticalAlignment="Center"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="20"
                        Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnCopyInstallTextClicked}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/CopyInstallText')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Click="{x:Bind OnInstallWithCmdClicked}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/InstallWithCmd')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE756;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>

                    <ToolTipService.ToolTip>
                        <ToolTip
                            MaxWidth="9999"
                            Padding="0"
                            Background="Transparent">

                            <Grid>
                                <SystemBackdropElement CornerRadius="{StaticResource ControlCornerRadius}" SystemBackdrop="{StaticResource AcrylicBackgroundFillColorDefaultBackdrop}" />
                                <TextBlock Padding="{StaticResource ToolTipBorderPadding}" Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ViewMore')}" />
                            </Grid>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                </Button>
            </Grid>

            <MenuFlyoutSeparator Grid.Row="1" />

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Visible"
                VerticalScrollMode="Enabled">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  忽略安装程序哈希检查失败  -->
                    <Grid
                        Grid.Row="0"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatch')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind AllowHashMismatch, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatchOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowHashMismatchOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnAllowHashMismatchToggled}" />
                    </Grid>

                    <!--  是否跳过商店策略检查  -->
                    <Grid
                        Grid.Row="1"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/BypassIsStoreClientBlockedPolicyCheck')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind BypassIsStoreClientBlockedPolicyCheck, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/BypassIsStoreClientBlockedPolicyCheckOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/BypassIsStoreClientBlockedPolicyCheckOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnBypassIsStoreClientBlockedPolicyCheckToggled}" />
                    </Grid>

                    <!--  是否允许升级到某一个未知版本  -->
                    <Grid
                        Grid.Row="2"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowUpgradeToUnknownVersion')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind AllowUpgradeToUnknownVersion, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowUpgradeToUnknownVersionOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowUpgradeToUnknownVersionOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnAllowUpgradeToUnknownVersionToggled}" />
                    </Grid>

                    <!--  是否强制安装  -->
                    <Grid
                        Grid.Row="3"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ForceInstall')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind ForceInstall, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ForceInstallOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ForceInstallOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnForceInstallToggled}" />
                    </Grid>

                    <!--  安装包安装范围  -->
                    <Grid
                        Grid.Row="4"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageInstallScope')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind PackageInstallScopeList}"
                            SelectedItem="{x:Bind PackageInstallScope, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnPackageInstallScopeSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <!--  应用安装模式  -->
                    <Grid
                        Grid.Row="5"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageInstallMode')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind PackageInstallModeList}"
                            SelectedItem="{x:Bind PackageInstallMode, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnPackageInstallModeSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <!--  应用安装路径  -->
                    <Grid
                        Grid.Row="6"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageInstallPath')}" />

                            <TextBlock
                                Margin="0,0,5,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"
                                Visibility="{x:Bind CheckPackagePath(PackageInstallPath), Mode=OneWay}">

                                <Hyperlink Click="{x:Bind OnPackageInstallPathClicked}" UnderlineStyle="None">
                                    <Run Text="{x:Bind PackageInstallPath, Mode=OneWay}" />
                                </Hyperlink>

                                <ToolTipService.ToolTip>
                                    <ToolTip
                                        MaxWidth="9999"
                                        Padding="0"
                                        Background="Transparent">

                                        <Grid>
                                            <SystemBackdropElement CornerRadius="{StaticResource ControlCornerRadius}" SystemBackdrop="{StaticResource AcrylicBackgroundFillColorDefaultBackdrop}" />

                                            <StackPanel Padding="{StaticResource ToolTipBorderPadding}" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/PackageInstallPath')}" />
                                                <TextBlock Text="{x:Bind PackageInstallPath, Mode=OneWay}" />
                                                <MenuFlyoutSeparator Margin="4,3" />
                                                <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/OpenFolder')}" />
                                            </StackPanel>
                                        </Grid>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Click="{x:Bind OnChangePackageInstallPathClicked}"
                            Content="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/ChangeFolder')}" />
                    </Grid>

                    <!--  允许的处理器架构  -->
                    <Grid
                        Grid.Row="7"
                        Height="60"
                        Margin="0,0,0,2"
                        Padding="16,0,22,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('WinGetAppsVersionOptions/AllowedArchitectures')}" />

                        <ToggleButton
                            Grid.Column="1"
