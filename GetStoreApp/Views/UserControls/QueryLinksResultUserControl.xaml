<UserControl
    x:Class="GetStoreApp.Views.UserControls.QueryLinksResultUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:GetStoreApp.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:GetStoreApp.Models"
    xmlns:rootservice="using:GetStoreApp.Services.Root"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="HyperlinkButtonBackgroundPressed" Color="Transparent" />

        <XamlUICommand x:Name="DownloadCommand" ExecuteRequested="{x:Bind OnDownloadExecuteRequested}" />
        <XamlUICommand x:Name="OpenLinkCommand" ExecuteRequested="{x:Bind OnOpenLinkExecuteRequested}" />
        <XamlUICommand x:Name="CopyLinkCommand" ExecuteRequested="{x:Bind OnCopyLinkExecuteRequested}" />
        <XamlUICommand x:Name="CopyInformationCommand" ExecuteRequested="{x:Bind OnCopyInformationExecuteRequested}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  查询链接结果显示栏  -->
        <InfoBar
            Grid.Row="0"
            Margin="30,5,30,3"
            IsClosable="False"
            IsIconVisible="False"
            IsOpen="True"
            Severity="Success">

            <Grid
                Height="60"
                Padding="0,8,0,8"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontSize="16"
                    Glyph="&#xE71E;" />

                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueryResult')}" />

                <AppBarSeparator Grid.Column="2" Margin="10,0,10,0" />

                <StackPanel Grid.Column="3" VerticalAlignment="Center">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueriedAppType')}" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/NonPackagedApp')}"
                            Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsPackagedApp), Mode=OneWay}" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/PackagedApp')}"
                            Visibility="{x:Bind IsPackagedApp, Mode=OneWay}" />
                    </Grid>

                    <TextBlock Text="{x:Bind x:String.Format(QueryLinksResultCountInfoString, QueryLinksResultCollection.Count), Mode=OneWay}" />
                </StackPanel>

                <CommandBar
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    DefaultLabelPosition="Right">

                    <CommandBar.PrimaryCommands>
                        <AppBarButton Click="{x:Bind OnBackToHomePageClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/BackToHomePage')}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE845;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.PrimaryCommands>
                </CommandBar>
            </Grid>
        </InfoBar>

        <!--  查询链接结果  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="30,0,30,0"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">

            <Grid Margin="0,0,0,30">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  查询链接结果信息栏  -->
                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Visibility="{x:Bind IsAppInfoVisible, Mode=OneWay}">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Row="0"
                        Height="50"
                        Padding="16,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xE946;" />

                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueriedAppInfo')}" />

                        <CommandBar
                            Grid.Column="2"
                            Margin="0,0,-15,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            DefaultLabelPosition="Right"
                            Style="{StaticResource CommandBarStyle}">

                            <CommandBar.PrimaryCommands>
                                <AppBarButton Click="{x:Bind OnCopyQueriedAppInfoClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyQueriedAppInfo')}">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton Click="{x:Bind OnLearnMoreClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/LearnMore')}">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE890;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar.PrimaryCommands>
                        </CommandBar>
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        Padding="44,16,26,16"
                        RowSpacing="6">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueriedAppName')}" />

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Name, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueriedAppPublisher')}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Publisher, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/QueriedAppDescription')}" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppInfo.Description, Mode=OneWay}"
                            TextAlignment="Justify"
                            TextWrapping="Wrap" />
                    </Grid>
                </Grid>

                <!--  查询链接结果列表  -->
                <Grid
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,1,1,0"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Row="0"
                        Height="50"
                        Padding="16,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xE8FD;" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/FileList')}" />

                        <CommandBar
                            x:Name="NormalMode"
                            Grid.Column="2"
                            Margin="0,0,-15,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            DefaultLabelPosition="Right"
                            Style="{StaticResource CommandBarStyle}"
                            Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsSelectMode), Mode=OneWay}">

                            <CommandBar.PrimaryCommands>
                                <AppBarButton
                                    Click="{x:Bind OnSelectClicked}"
                                    Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/Select')}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/SelectToolTip')}">

                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE762;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar.PrimaryCommands>
                        </CommandBar>

                        <CommandBar
                            x:Name="SelectMode"
                            Grid.Column="2"
                            Margin="0,0,-15,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            DefaultLabelPosition="Right"
                            Style="{StaticResource CommandBarStyle}"
                            Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                            <CommandBar.PrimaryCommands>
                                <AppBarButton Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyOptions')}" ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyOptionsToolTip')}">

                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </AppBarButton.Icon>

                                    <AppBarButton.Flyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem
                                                Click="{x:Bind OnCopySelectedLinkClicked}"
                                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopySelectedLink')}"
                                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopySelectedLinkToolTip')}" />

                                            <MenuFlyoutItem
                                                Click="{x:Bind OnCopySelectedClicked}"
                                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopySelectedContent')}"
                                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopySelectedContentToolTip')}" />
                                        </MenuFlyout>
                                    </AppBarButton.Flyout>
                                </AppBarButton>

                                <AppBarButton Click="{x:Bind OnDownloadSelectedClicked}" Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/DownloadSelected')}">

                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE74B;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton
                                    Click="{x:Bind OnCancelClicked}"
                                    Label="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/Cancel')}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CancelToolTip')}">

                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE711;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar.PrimaryCommands>
                        </CommandBar>
                    </Grid>

                    <ListView
                        Grid.Row="1"
                        CornerRadius="0"
                        IsItemClickEnabled="{x:Bind IsSelectMode, Mode=OneWay}"
                        ItemClick="{x:Bind OnItemClick}"
                        ItemsSource="{x:Bind QueryLinksResultCollection}"
                        SelectionMode="None"
                        Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(QueryLinksResultCollection.Count), Mode=OneWay}">

                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ItemsControl.ItemContainerTransitions>
                            <TransitionCollection />
                        </ItemsControl.ItemContainerTransitions>

                        <ListView.Header>
                            <Grid
                                Height="35"
                                Padding="6,0,0,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Name="SelectHeaderText"
                                    Grid.Column="0"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/SelectHeader')}"
                                    Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                                    <Hyperlink Click="{x:Bind OnSelectHeaderClicked}" UnderlineStyle="None">
                                        <Run Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/Select')}" />
                                    </Hyperlink>
                                </TextBlock>

                                <TextBlock
                                    x:Name="FileNameHeaderText"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/FileName')}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/FileName')}" Visibility="{x:Bind FileNameHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <TextBlock
                                    x:Name="FileSizeHeaderText"
                                    Grid.Column="2"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/FileSize')}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/FileSize')}" Visibility="{x:Bind FileSizeHeaderText.IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <TextBlock
                                    Grid.Column="3"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/Options')}"
                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/OptionsToolTip')}" />
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:QueryLinksResultModel">
                                <Grid
                                    Height="35"
                                    Padding="6,0,0,0"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        Grid.Column="0"
                                        Width="50"
                                        MinWidth="0"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                        IsThreeState="False"
                                        Visibility="{x:Bind IsSelectMode, Mode=OneWay}">

                                        <ToolTipService.ToolTip>
                                            <ToolTip>
                                                <Grid>
                                                    <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/Selected')}" Visibility="{x:Bind IsSelected, Mode=OneWay}" />
                                                    <TextBlock Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/UnSelected')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsSelected), Mode=OneWay}" />
                                                </Grid>
                                            </ToolTip>
                                        </ToolTipService.ToolTip>
                                    </CheckBox>

                                    <HyperlinkButton
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Command="{StaticResource DownloadCommand}"
                                        CommandParameter="{x:Bind}"
                                        IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}">

                                        <TextBlock
                                            x:Name="FileNameText"
                                            HorizontalAlignment="Left"
                                            Text="{x:Bind FileName}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap">

                                            <ToolTipService.ToolTip>
                                                <ToolTip Content="{x:Bind FileName}" Visibility="{Binding ElementName=FileNameText, Path=IsTextTrimmed, Mode=OneWay}" />
                                            </ToolTipService.ToolTip>
                                        </TextBlock>

                                        <HyperlinkButton.ContextFlyout>
                                            <MenuFlyout Placement="Bottom">
                                                <MenuFlyoutItem
                                                    Command="{StaticResource CopyLinkCommand}"
                                                    CommandParameter="{x:Bind FileLink}"
                                                    IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                                    Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyLink')}"
                                                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyLinkToolTip')}">

                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE8C8;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </HyperlinkButton.ContextFlyout>
                                    </HyperlinkButton>

                                    <TextBlock
                                        x:Name="FileSizeText"
                                        Grid.Column="2"
                                        MinWidth="50"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind FileSize}"
                                        TextAlignment="Left"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">

                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="{x:Bind FileSize}" Visibility="{Binding ElementName=FileSizeText, Path=IsTextTrimmed, Mode=OneWay}" />
                                        </ToolTipService.ToolTip>
                                    </TextBlock>

                                    <HyperlinkButton
                                        Grid.Column="3"
                                        Margin="0,0,5,0"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Command="{StaticResource OpenLinkCommand}"
                                        CommandParameter="{x:Bind FileLink}"
                                        Content="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/OpenLink')}"
                                        IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                        ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/OpenLinkToolTip')}" />

                                    <Grid.ContextFlyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem
                                                Command="{StaticResource CopyInformationCommand}"
                                                CommandParameter="{x:Bind}"
                                                IsEnabled="{x:Bind IsSelectMode.Equals(x:False), Mode=OneWay}"
                                                Text="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyInformation')}"
                                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.GetLocalized('QueryLinksResult/CopyInformationToolTip')}">

                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8C8;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
